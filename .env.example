# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── 미국 주식/ETF 자동매매 ─────────────────────────────
# Alpaca (paper trading: https://alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading (모의)
# ALPACA_BASE_URL=https://api.alpaca.markets       # live trading (실거래)

# ── 데이터 소스 (선택) ────────────────────────────────
# Polygon.io — 미국 주식 고품질 데이터 (무료 플랜 있음)
POLYGON_API_KEY=

# ── 한국 주식 (선택, KIS API) ─────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_MOCK=true   # true=모의투자, false=실거래

# 금융감독원 DART (한국 공시, 선택)
DART_API_KEY=

# ── DB / 캐시 (Phase 2+) ──────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/inv
REDIS_URL=redis://localhost:6379
